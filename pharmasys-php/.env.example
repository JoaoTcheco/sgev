# ============================================================
#  PharmaSys — Variáveis de Ambiente (.env)
# ============================================================
#  Copie este ficheiro para  .env   e ajuste os valores.
#  Se o ficheiro .env não existir, o sistema usa os valores
#  por defeito definidos em  app/config.php.
# ============================================================

# --- Ambiente ---
APP_ENV=local              # local | production
APP_DEBUG=true
APP_URL=http://127.0.0.1:8090

# --- Base de dados ---
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=pharmasys
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4
# DB_SOCKET=/tmp/mariadb/run/mysql.sock   # (opcional) socket Unix

# --- Empresa / Farmácia (aparece em recibos) ---
PHARMACY_NAME=PharmaSys
COMPANY_NAME="PharmaSys, Lda."
COMPANY_NUIT=400000000
COMPANY_ADDRESS="Av. 25 de Setembro, Maputo"
COMPANY_PHONE=+258840000000
COMPANY_EMAIL=geral@pharmasys.co.mz

# --- E-mail (SMTP) — opcional ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=tls
